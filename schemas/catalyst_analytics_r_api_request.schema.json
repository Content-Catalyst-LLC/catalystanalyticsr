{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-api-request-v1.json",
  "title": "Catalyst Analytics R API request",
  "type": "object",
  "additionalProperties": false,
  "required": [
