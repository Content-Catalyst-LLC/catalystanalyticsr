    "request_type",
    "request_id",
    "endpoint",
    "payload",
    "actor",
    "context",
    "submitted_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "request_type": {
      "const": "catalyst_public_api_request"
    },
    "request_id": {
      "type": "string"
    },
    "endpoint": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "actor": {
      "type": "object"
    },
    "context": {
      "type": "object"
    },
    "submitted_at": {
      "type": "string"
    }
  }
}
