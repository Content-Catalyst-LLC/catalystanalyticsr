{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-platform-handoff-export-v1.json",
  "title": "Sustainable Catalyst platform handoff export",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "export_type",
    "project_id",
    "project_fingerprint",
    "targets",
    "package",
    "created_at",
    "file_count",
    "files",
    "integrity",
    "boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "export_type": {
      "const": "sustainable_catalyst_platform_handoff_bundle"
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "file_count": {
      "type": "integer",
      "minimum": 1
    },
    "files": {
      "type": "array"
    },
    "boundary": {
      "type": "object"
    }
  }
}
