{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-uncertainty-input-v1.schema.json",
  "title": "Catalyst Analytics R Uncertainty Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario",
    "sampling",
    "n",
    "seed",
    "metrics",
    "thresholds"
  ],
  "properties": {
    "scenario": {
      "type": "object"
    },
    "sampling": {
      "enum": [
        "monte_carlo",
        "latin_hypercube"
      ]
    },
    "n": {
      "type": "integer",
      "minimum": 1
    },
    "seed": {
      "type": "integer"
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "number"
          },
          {
            "type": "object",
            "required": [
              "value",
              "operator"
            ],
            "properties": {
              "value": {
                "type": "number"
              },
              "operator": {
                "enum": [
                  ">=",
                  "<=",
                  ">",
                  "<",
                  "=="
                ]
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  }
}
