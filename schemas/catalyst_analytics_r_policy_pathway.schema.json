{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst_analytics_r_policy_pathway.schema.json",
  "title": "Catalyst Analytics R adaptive policy pathway",
  "type": "object",
  "required": [
    "schema_version",
    "pathway_type",
    "id",
    "title",
    "stages",
    "objectives",
    "metadata",
    "boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "pathway_type": {
      "const": "adaptive_policy_pathway"
    },
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "stages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "id",
          "label",
          "start",
          "end",
          "actions",
          "triggers",
          "decision_gate"
        ]
      }
    },
    "objectives": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    },
    "boundary": {
      "type": "object",
      "required": [
        "human_decision_gates_required",
        "triggers_are_review_prompts"
      ]
    }
  }
}
