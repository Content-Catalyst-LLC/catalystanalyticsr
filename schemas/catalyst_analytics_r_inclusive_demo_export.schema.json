{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst_analytics_r_inclusive_demo_export.schema.json",
  "title": "Catalyst Analytics R Browser Inclusive Development Export",
  "type": "object",
  "required": [
    "schema_version",
    "export_type",
    "demo_version",
    "generated_at",
    "contract",
    "inputs",
    "capital_accounts",
    "inclusive_wealth",
    "adjusted_net_savings",
    "human_development",
    "distribution",
    "intergenerational",
    "composite",
    "review_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.6.0"
    },
    "export_type": {
      "const": "browser_inclusive_development"
    },
    "demo_version": {
      "const": "1.6.0"
    },
    "generated_at": {
      "type": "string"
    },
    "contract": {
      "type": "object",
      "required": [
        "parity_status",
        "compatible_repository_version",
        "wealth_contract_version",
        "human_development_contract_version",
        "distribution_contract_version",
        "composite_score_contract_version",
        "inclusive_development_contract_version"
      ]
    },
    "inputs": {
      "type": "object"
    },
    "capital_accounts": {
      "type": "object"
    },
    "inclusive_wealth": {
      "type": "object",
      "required": [
        "opening",
        "closing",
        "change",
        "per_capita_opening",
        "per_capita_closing",
        "produced_share",
        "human_share",
        "natural_share"
      ]
    },
    "adjusted_net_savings": {
      "type": "object"
    },
    "human_development": {
      "type": "object"
    },
    "distribution": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://sustainablecatalyst.com/schemas/catalyst_analytics_r_distribution.schema.json",
      "title": "Catalyst Analytics R Distribution Contract",
      "type": "object",
      "required": [
        "schema_version",
        "analysis_type",
        "indicator",
        "summary",
        "group_summary"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0.0"
        },
        "analysis_type": {
          "const": "distributional"
        },
        "indicator": {
          "type": "string"
        },
        "summary": {
          "type": "object",
          "required": [
            "weighted_mean",
            "gini",
            "top_10_share",
            "bottom_40_share",
            "share_below_social_floor"
          ],
          "properties": {
            "weighted_mean": {
              "type": "number"
            },
            "gini": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "top_10_share": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "bottom_40_share": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "share_below_social_floor": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": true
        },
        "group_summary": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "group",
              "resource_share",
              "population_share"
            ],
            "properties": {
              "group": {
                "type": "string"
              },
              "resource_share": {
                "type": "number"
              },
              "population_share": {
                "type": "number"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "intergenerational": {
      "type": "object"
    },
    "composite": {
      "type": "object",
      "required": [
        "definition",
        "score",
        "component_scores",
        "weight_sensitivity"
      ]
    },
    "review_boundary": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
