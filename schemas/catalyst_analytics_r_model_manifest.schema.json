{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-model-manifest.schema.json",
  "title": "Catalyst Analytics R Model Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "id", "version", "title", "description",
    "required_states", "default_state", "default_parameters", "default_policy",
    "integration_methods", "state_units", "flow_map", "flow_units",
    "indicator_map", "metadata"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]*$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "required_states": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "default_state": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "number" } },
    "default_parameters": { "type": "object", "additionalProperties": { "type": ["number", "null"] } },
    "default_policy": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "number" } },
    "integration_methods": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["rk4", "euler"] }
    },
    "state_units": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "string", "minLength": 1 } },
    "flow_map": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "string", "minLength": 1 } },
    "flow_units": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "string", "minLength": 1 } },
    "indicator_map": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "unit", "direction"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "unit": { "type": "string", "minLength": 1 },
          "direction": { "enum": ["higher_better", "lower_better", "contextual"] }
        }
      }
    },
    "metadata": { "type": "object" }
  }
}
