{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-platform-handoff-v1.json",
  "title": "Sustainable Catalyst platform handoff",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "handoff_type",
    "target",
    "project_id",
    "project_fingerprint",
    "title",
    "payload",
    "provenance",
    "review",
    "boundary",
    "created_at",
    "package_version"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "target": {
      "enum": [
        "site_intelligence",
        "research_lab",
        "workbench",
        "catalyst_canvas",
        "decision_studio",
        "knowledge_library"
      ]
    },
    "project_id": {
      "type": "string"
    },
    "project_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "payload": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    },
    "review": {
      "type": "object",
      "required": [
        "status",
        "human_reviewer_required"
      ]
    },
    "boundary": {
      "type": "object",
      "required": [
        "human_review_required"
      ]
    },
    "package_version": {
      "type": "string"
    }
  }
}
