{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-project-handoff-v1.json",
  "title": "Catalyst Analytics R project handoff",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "handoff_type",
    "project_id",
    "project_fingerprint",
    "title",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "handoff_type": {
      "enum": [
        "decision_studio_analytical_project",
        "knowledge_library_methodology_package"
      ]
    },
    "project_id": {
      "type": "string"
    },
    "project_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "title": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    }
  }
}
