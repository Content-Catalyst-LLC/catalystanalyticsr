{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-institutional-governance-export-v1.json",
  "title": "Institutional governance export manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "export_type",
    "workflow_id",
    "project_id",
    "package",
    "created_at",
    "file_count",
    "files",
    "integrity",
    "boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "export_type": {
      "const": "institutional_governance_bundle"
    },
    "workflow_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "package": {
      "type": "object"
    },
    "created_at": {
      "type": "string"
    },
    "file_count": {
      "type": "integer",
      "minimum": 1
    },
    "files": {
      "type": "array"
    },
    "integrity": {
      "type": "object"
    },
    "boundary": {
      "type": "object"
    }
  }
}
