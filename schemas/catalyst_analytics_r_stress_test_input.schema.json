{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-stress-test-input-v1.schema.json",
  "title": "Catalyst Analytics R Stress Test Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "baseline_scenario",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "baseline_scenario": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "description",
          "shocks"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "shocks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "target",
                "mode",
                "value"
              ],
              "properties": {
                "target": {
                  "type": "string",
                  "pattern": "^(parameters|policy|initial_state|constraints)\\.[A-Za-z][A-Za-z0-9_]*$"
                },
                "mode": {
                  "enum": [
                    "set",
                    "add",
                    "multiply"
                  ]
                },
                "value": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}
