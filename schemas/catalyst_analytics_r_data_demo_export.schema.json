{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-data-demo-export-v1.4.schema.json",
  "title": "Catalyst Analytics R Data Intake Browser Export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "demo",
    "demo_version",
    "engine",
    "generated_at",
    "dataset",
    "quality",
    "indicator_registry",
    "indicator_result",
    "trace",
    "boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.4.0"
    },
    "demo": {
      "const": "Catalyst Analytics R Demo"
    },
    "demo_version": {
      "const": "1.4.0"
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "compatible_repository_version",
        "parity_status",
        "dataset_contract_version",
        "indicator_contract_version"
      ],
      "properties": {
        "type": {
          "const": "browser_data_intake"
        },
        "compatible_repository_version": {
          "const": "0.5.0"
        },
        "parity_status": {
          "const": "mapped_data_indicator_contract"
        },
        "dataset_contract_version": {
          "const": "1.0.0"
        },
        "indicator_contract_version": {
          "const": "1.0.0"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "dataset": {
      "type": "object",
      "required": [
        "schema_version",
        "id",
        "title",
        "time_field",
        "entity_fields",
        "units",
        "source",
        "currency",
        "records"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0.0"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "time_field": {
          "type": "string"
        },
        "entity_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "units": {
          "type": "object"
        },
        "source": {
          "type": "object"
        },
        "currency": {
          "type": "object"
        },
        "records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object"
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "required": [
        "row_count",
        "column_count",
        "missing_cells",
        "duplicate_rows",
        "duplicate_keys",
        "flags"
      ],
      "properties": {
        "row_count": {
          "type": "integer",
          "minimum": 1
        },
        "column_count": {
          "type": "integer",
          "minimum": 1
        },
        "missing_cells": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_rows": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_keys": {
          "type": "integer",
          "minimum": 0
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "indicator_registry": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "version",
          "title",
          "formula",
          "required_fields",
          "unit",
          "direction",
          "aggregation"
        ]
      }
    },
    "indicator_result": {
      "type": "object",
      "required": [
        "indicator",
        "values"
      ],
      "properties": {
        "indicator": {
          "type": "object",
          "required": [
            "id",
            "version",
            "title",
            "formula",
            "required_fields",
            "unit",
            "direction",
            "aggregation"
          ]
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "value"
            ]
          }
        }
      }
    },
    "trace": {
      "type": "object"
    },
    "boundary": {
      "type": "object",
      "required": [
        "source_verified",
        "unit_compatibility_verified",
        "causal_claim",
        "professional_advice"
      ],
      "properties": {
        "source_verified": {
          "const": false
        },
        "unit_compatibility_verified": {
          "const": false
        },
        "causal_claim": {
          "const": false
        },
        "professional_advice": {
          "const": false
        }
      }
    }
  }
}
