{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-project-v1.json",
  "title": "Catalyst Analytics R reproducible project",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "project_type",
    "id",
    "title",
    "description",
    "owner",
    "scope",
    "tags",
    "scenarios",
    "datasets",
    "models",
    "parameter_sets",
    "runs",
    "indicators",
    "plots",
    "notes",
    "reviews",
    "snapshots",
    "publications",
    "environment",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "project_type": {
      "const": "reproducible_analytical_project"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scenarios": {
      "type": "object"
    },
    "datasets": {
      "type": "object"
    },
    "models": {
      "type": "object"
    },
    "parameter_sets": {
      "type": "object"
    },
    "runs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "schema_version",
          "id",
          "label",
          "status",
          "input_hash",
          "output_hash",
          "package",
          "environment",
          "result_summary",
          "warnings",
          "errors",
          "review_status"
        ],
        "properties": {
          "schema_version": {
            "const": "1.0.0"
          },
          "status": {
            "enum": [
              "completed",
              "failed"
            ]
          },
          "input_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{32}$"
          },
          "output_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{32}$"
          }
        }
      }
    },
    "indicators": {
      "type": "object"
    },
    "plots": {
      "type": "object"
    },
    "notes": {
      "type": "array"
    },
    "reviews": {
      "type": "array"
    },
    "snapshots": {
      "type": "array"
    },
    "publications": {
      "type": "array"
    },
    "environment": {
      "type": "object",
      "required": [
        "schema_version",
        "r",
        "operating_system",
        "packages"
      ]
    },
    "metadata": {
      "type": "object",
      "required": [
        "package_version",
        "created_at",
        "updated_at",
        "review_status",
        "publication_status"
      ]
    }
  }
}
