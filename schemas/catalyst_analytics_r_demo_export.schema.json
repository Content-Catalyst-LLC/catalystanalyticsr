{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-demo-export-v1.1.schema.json",
  "title": "Catalyst Analytics R Demo Export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "demo", "demo_version", "engine", "generated_at",
    "inputs", "canonical_scenario", "final", "composite_score", "budget_ratio",
    "interpretation_notes", "trajectory", "boundary"
  ],
  "properties": {
    "schema_version": { "const": "1.1.0" },
    "demo": { "const": "Catalyst Analytics R Demo" },
    "demo_version": { "const": "1.1.0" },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "compatible_repository_version", "parity_status"],
      "properties": {
        "type": { "const": "browser_simplified" },
        "compatible_repository_version": { "const": "0.2.0" },
        "parity_status": { "const": "mapped_contract" }
      }
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "inputs": { "$ref": "#/$defs/scenarioInput" },
    "canonical_scenario": {
      "type": "object",
      "required": ["schema_version", "id", "model", "time", "initial_state", "policy", "parameters", "constraints"],
      "properties": {
        "schema_version": { "const": "1.0.0" },
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]*$" },
        "model": {
          "type": "object",
          "required": ["id", "version"],
          "properties": {
            "id": { "const": "khncpa" },
            "version": { "const": "1.0.0" }
          }
        }
      },
      "additionalProperties": true
    },
    "final": { "$ref": "#/$defs/trajectoryRow" },
    "composite_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "budget_ratio": { "type": "number", "minimum": 0 },
    "interpretation_notes": {
      "type": "array", "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "trajectory": {
      "type": "array",
      "items": { "$ref": "#/$defs/trajectoryRow" }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forecast", "compliance", "professional_advice"],
      "properties": {
        "forecast": { "const": false },
        "compliance": { "const": false },
        "professional_advice": { "const": false }
      }
    }
  },
  "$defs": {
    "scenarioInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioName", "years", "savings", "emissionsIntensity", "adaptation",
        "restoration", "humanInvestment", "initialCapital", "initialHuman",
        "initialNatural", "emissionsBudget"
      ],
      "properties": {
        "scenarioName": { "type": "string", "minLength": 1, "maxLength": 80 },
        "years": { "type": "integer", "minimum": 5, "maximum": 40 },
        "savings": { "type": "number", "minimum": 0.05, "maximum": 0.45 },
        "emissionsIntensity": { "type": "number", "minimum": 0.01, "maximum": 0.2 },
        "adaptation": { "type": "number", "minimum": 0, "maximum": 0.25 },
        "restoration": { "type": "number", "minimum": 0, "maximum": 0.2 },
        "humanInvestment": { "type": "number", "minimum": 0, "maximum": 0.2 },
        "initialCapital": { "type": "number", "minimum": 10, "maximum": 1000 },
        "initialHuman": { "type": "number", "minimum": 10, "maximum": 1000 },
        "initialNatural": { "type": "number", "minimum": 10, "maximum": 1000 },
        "emissionsBudget": { "type": "number", "minimum": 10, "maximum": 1000 }
      }
    },
    "trajectoryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "year", "produced_capital", "human_capital", "natural_capital",
        "cumulative_emissions", "adjusted_savings", "composite_score"
      ],
      "properties": {
        "year": { "type": "integer", "minimum": 0 },
        "produced_capital": { "type": "number" },
        "human_capital": { "type": "number" },
        "natural_capital": { "type": "number" },
        "cumulative_emissions": { "type": "number", "minimum": 0 },
        "adjusted_savings": { "type": "number" },
        "composite_score": { "type": "number" }
      }
    }
  }
}
