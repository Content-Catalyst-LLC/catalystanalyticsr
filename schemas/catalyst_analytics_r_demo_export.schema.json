{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-analytics-r-demo-export-v1.2.schema.json",
  "title": "Catalyst Analytics R Comparative Browser Export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "demo",
    "demo_version",
    "engine",
    "generated_at",
    "inputs",
    "canonical_scenarios",
    "comparison",
    "trajectories",
    "interpretation_notes",
    "boundary",
    "uncertainty"
  ],
  "properties": {
    "schema_version": {
      "const": "1.3.0"
    },
    "demo": {
      "const": "Catalyst Analytics R Demo"
    },
    "demo_version": {
      "const": "1.3.0"
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "compatible_repository_version",
        "parity_status",
        "comparison_contract_version",
        "uncertainty_contract_version"
      ],
      "properties": {
        "type": {
          "const": "browser_simplified"
        },
        "compatible_repository_version": {
          "const": "0.4.0"
        },
        "parity_status": {
          "const": "mapped_uncertainty_contract"
        },
        "comparison_contract_version": {
          "const": "1.0.0"
        },
        "uncertainty_contract_version": {
          "const": "1.0.0"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shared",
        "baseline",
        "policy"
      ],
      "properties": {
        "shared": {
          "$ref": "#/$defs/shared"
        },
        "baseline": {
          "$ref": "#/$defs/scenarioInput"
        },
        "policy": {
          "$ref": "#/$defs/scenarioInput"
        }
      }
    },
    "canonical_scenarios": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "id",
          "title",
          "role",
          "model",
          "time",
          "initial_state",
          "policy",
          "parameters",
          "constraints"
        ],
        "properties": {
          "schema_version": {
            "const": "1.0.0"
          },
          "role": {
            "enum": [
              "baseline",
              "intervention"
            ]
          }
        }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_id",
        "policy_id",
        "deltas",
        "tradeoff",
        "pareto",
        "budget"
      ],
      "properties": {
        "baseline_id": {
          "$ref": "#/$defs/id"
        },
        "policy_id": {
          "$ref": "#/$defs/id"
        },
        "deltas": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/delta"
          }
        },
        "tradeoff": {
          "type": "object",
          "required": [
            "classification",
            "improved_metrics",
            "worsened_metrics",
            "tied_metrics"
          ],
          "properties": {
            "classification": {
              "enum": [
                "dominates_baseline",
                "dominated_by_baseline",
                "tradeoff",
                "equivalent"
              ]
            },
            "improved_metrics": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/id"
              }
            },
            "worsened_metrics": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/id"
              }
            },
            "tied_metrics": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/id"
              }
            }
          }
        },
        "pareto": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "baseline_non_dominated",
            "policy_non_dominated"
          ],
          "properties": {
            "baseline_non_dominated": {
              "type": "boolean"
            },
            "policy_non_dominated": {
              "type": "boolean"
            }
          }
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "value",
            "baseline_within_budget",
            "policy_within_budget"
          ],
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0
            },
            "baseline_within_budget": {
              "type": "boolean"
            },
            "policy_within_budget": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "trajectories": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline",
        "policy"
      ],
      "properties": {
        "baseline": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/trajectoryRow"
          }
        },
        "policy": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/trajectoryRow"
          }
        }
      }
    },
    "interpretation_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forecast",
        "compliance",
        "autonomous_decision",
        "professional_advice"
      ],
      "properties": {
        "forecast": {
          "const": false
        },
        "compliance": {
          "const": false
        },
        "autonomous_decision": {
          "const": false
        },
        "professional_advice": {
          "const": false
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "sampling",
        "seed",
        "requested",
        "completed",
        "failed",
        "specifications",
        "summary",
        "probabilities",
        "sensitivity",
        "failures"
      ],
      "properties": {
        "contract_version": {
          "const": "1.0.0"
        },
        "sampling": {
          "enum": [
            "monte_carlo",
            "latin_hypercube"
          ]
        },
        "seed": {
          "type": "integer"
        },
        "requested": {
          "type": "integer",
          "minimum": 1
        },
        "completed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "specifications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uncertaintySpec"
          }
        },
        "summary": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "probabilities": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "sensitivity": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "failures": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]*$",
      "minLength": 1,
      "maxLength": 100
    },
    "shared": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "years",
        "initialCapital",
        "initialHuman",
        "initialNatural",
        "emissionsBudget"
      ],
      "properties": {
        "years": {
          "type": "integer",
          "minimum": 5,
          "maximum": 40
        },
        "initialCapital": {
          "type": "number",
          "minimum": 10,
          "maximum": 1000
        },
        "initialHuman": {
          "type": "number",
          "minimum": 10,
          "maximum": 1000
        },
        "initialNatural": {
          "type": "number",
          "minimum": 10,
          "maximum": 1000
        },
        "emissionsBudget": {
          "type": "number",
          "minimum": 10,
          "maximum": 1000
        }
      }
    },
    "scenarioInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioName",
        "role",
        "savings",
        "emissionsIntensity",
        "adaptation",
        "restoration",
        "humanInvestment"
      ],
      "properties": {
        "scenarioName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "role": {
          "enum": [
            "baseline",
            "intervention"
          ]
        },
        "savings": {
          "type": "number",
          "minimum": 0.05,
          "maximum": 0.45
        },
        "emissionsIntensity": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 0.2
        },
        "adaptation": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.25
        },
        "restoration": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.2
        },
        "humanInvestment": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.2
        }
      }
    },
    "delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric",
        "label",
        "direction",
        "baseline_value",
        "policy_value",
        "absolute_delta",
        "percentage_delta",
        "outcome"
      ],
      "properties": {
        "metric": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "type": "string"
        },
        "direction": {
          "enum": [
            "higher_better",
            "lower_better"
          ]
        },
        "baseline_value": {
          "type": "number"
        },
        "policy_value": {
          "type": "number"
        },
        "absolute_delta": {
          "type": "number"
        },
        "percentage_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "outcome": {
          "enum": [
            "improved",
            "worsened",
            "tied"
          ]
        }
      }
    },
    "trajectoryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "year",
        "produced_capital",
        "human_capital",
        "natural_capital",
        "cumulative_emissions",
        "adjusted_savings",
        "composite_score"
      ],
      "properties": {
        "year": {
          "type": "integer",
          "minimum": 0
        },
        "produced_capital": {
          "type": "number"
        },
        "human_capital": {
          "type": "number"
        },
        "natural_capital": {
          "type": "number"
        },
        "cumulative_emissions": {
          "type": "number",
          "minimum": 0
        },
        "adjusted_savings": {
          "type": "number"
        },
        "composite_score": {
          "type": "number"
        }
      }
    },
    "uncertaintySpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "target",
        "distribution",
        "parameters",
        "label",
        "enabled"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]*$"
        },
        "target": {
          "type": "string",
          "pattern": "^(parameters|policy|initial_state|constraints)\\.[A-Za-z][A-Za-z0-9_]*$"
        },
        "distribution": {
          "enum": [
            "fixed",
            "uniform",
            "normal",
            "lognormal",
            "triangular",
            "beta",
            "discrete"
          ]
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}
