{
  "schema_version": "1.0.0",
  "analysis_id": "sample-climate-accounting",
  "title": "Synthetic climate, carbon, and natural-capital account",
  "dataset": {
    "id": "sample-climate-accounting-data",
    "time_field": "year",
    "entity_fields": ["region"],
    "units": {
      "emissions": "MtCO2e",
      "removals": "MtCO2e",
      "energy": "PJ",
      "gdp": "currency_index",
      "population": "million_persons",
      "opening_stock": "natural_capital_index",
      "closing_stock": "natural_capital_index"
    },
    "source": "inst/extdata/climate/sample_climate_accounting_source.json",
    "data": "inst/extdata/climate/sample_climate_accounting.csv"
  },
  "inventory": {
    "emissions_field": "emissions",
    "removals_field": "removals",
    "energy_field": "energy",
    "gdp_field": "gdp",
    "population_field": "population",
    "accounting_basis": "period_total",
    "gwp_basis": "AR6 GWP100 synthetic CO2e fixture"
  },
  "carbon_budget": {
    "budget": 300,
    "unit": "MtCO2e",
    "target_year": 2030,
    "target_net_emissions": 0
  },
  "natural_capital": {
    "opening_field": "opening_stock",
    "regeneration_field": "regeneration",
    "restoration_field": "restoration",
    "additions_field": "additions",
    "extraction_field": "extraction",
    "degradation_field": "degradation",
    "damages_field": "damages",
    "closing_field": "closing_stock"
  },
  "boundary_definitions": "examples/boundary_definitions.json"
}
