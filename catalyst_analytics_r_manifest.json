  "method_path": "question -> governed data and evidence -> models and scenarios -> uncertainty and evaluation -> connected lineage graph -> collaborative review -> decision record -> publication and cross-product handoff",
  "boundaries": [
    "educational decision support",
    "source and scope review required",
    "capital measurement review required",
    "shadow-price and valuation review required",
    "human-development goalpost review required",
    "social-floor and distribution-weight review required",
    "intergenerational discount-rate review required",
    "composite-weight review required",
    "not a forecast",
    "not compliance advice",
    "not professional advice",
    "reproducibility does not establish validity",
    "publication approval requires human review",
    "project handoffs are not autonomous decisions",
    "statistical association is not causal proof",
    "parallel-trends and no-interference assumptions require review",
    "synthetic controls require placebo and support review",
    "econometric outputs do not authorize policy"
